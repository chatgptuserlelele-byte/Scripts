local Toggle = ESPTab:CreateToggle({
   Name = "Toggle Tracers",
   CurrentValue = false,
   Flag = "TracersTogglePC", 
   Callback = function(Value)
       -- The variable (Value) is a boolean on whether the toggle is true or false
       _G.TracersEnabled = Value

       local Players = game:GetService("Players")
       local LocalPlayer = Players.LocalPlayer
       local RunService = game:GetService("RunService")
       local Camera = workspace.CurrentCamera

       -- Function to create/update the tracer frame
       local function updateTracer(player)
           if not _G.TracersEnabled then return end
           if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end

           local hrp = player.Character.HumanoidRootPart
           local screenPoint, onScreen = Camera:WorldToViewportPoint(hrp.Position)

           local tracerName = "Tracer_" .. player.Name
           local screenGui = game:GetService("CoreGui"):FindFirstChild("TopsyTracers")
           
           if not screenGui then
               screenGui = Instance.new("ScreenGui")
               screenGui.Name = "TopsyTracers"
               screenGui.Parent = game:GetService("CoreGui")
               screenGui.IgnoreGuiInset = true
           end

           local frame = screenGui:FindFirstChild(tracerName)
           if not frame and onScreen then
               frame = Instance.new("Frame")
               frame.Name = tracerName
               frame.Parent = screenGui
               frame.BorderSizePixel = 0
               frame.AnchorPoint = Vector2.new(0.5, 0)
           end

           if onScreen and frame then
               local startPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y) -- Bottom Middle
               local endPos = Vector2.new(screenPoint.X, screenPoint.Y)
               local distance = (endPos - startPos).Magnitude
               local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)

               frame.Visible = true
               frame.Size = UDim2.new(0, 1.5, 0, distance) -- Thickness of 1.5
               frame.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
               frame.Rotation = math.deg(angle) - 90
               frame.BackgroundColor3 = _G.Tracer_Color or Color3.fromRGB(255, 255, 255)
           elseif frame then
               frame.Visible = false
           end
       end

       -- THE LOOP
       if Value then
           RunService:BindToRenderStep("TracerLoopPC", 200, function()
               for _, player in ipairs(Players:GetPlayers()) do
                   if player ~= LocalPlayer then
                       updateTracer(player)
                   end
               end
           end)
       else
           -- CLEANUP
           RunService:UnbindFromRenderStep("TracerLoopPC")
           local screenGui = game:GetService("CoreGui"):FindFirstChild("TopsyTracers")
           if screenGui then screenGui:Destroy() end
       end
   end,
})
local ColorPicker = ESPTab:CreateColorPicker({
