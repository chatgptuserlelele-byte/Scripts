local Toggle = AimbotTab:CreateToggle({
   Name = "Toggle ESP",
   CurrentValue = false,
   Flag = "Toggle1", -- A flag is the identifier for the configuration file; make sure every element has a different flag if you're using configuration saving to ensure no overlaps
   Callback = function(Value)
   ESP_Active = Value -- 'Value' comes from your toggle's callback

local function applyESP(character)
    if not ESP_Active or not character or character == LocalPlayer.Character then return end
    
    local head = character:WaitForChild("Head", 10)
    if not head then return end

    -- 1. Red Glow (Highlight)
    if not character:FindFirstChild("ESPHighlight") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.Parent = character
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    end

    -- 2. Small Name Tag
    if not head:FindFirstChild("ESPNameTag") then
        local player = Players:GetPlayerFromCharacter(character)
        local billboard = Instance.new("BillboardGui", head)
        billboard.Name = "ESPNameTag"
        billboard.Size = UDim2.new(0, 80, 0, 20) -- Small container
        billboard.StudsOffset = Vector3.new(0, 2, 0)
        billboard.AlwaysOnTop = true
        
        local label = Instance.new("TextLabel", billboard)
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = player.DisplayName or player.Name
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextStrokeTransparency = 0.4
        label.TextSize = 10 -- Sharp, small text
        label.Font = Enum.Font.GothamBold
    end
end

if ESP_Active then
    -- Turn ON: Apply to current players and setup respawn listeners
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then applyESP(player.Character) end
        player.CharacterAdded:Connect(applyESP)
    end
else
    -- Turn OFF: Remove all ESP objects immediately
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then
            local h = player.Character:FindFirstChild("ESPHighlight")
            if h then h:Destroy() end
            local head = player.Character:FindFirstChild("Head")
            if head and head:FindFirstChild("ESPNameTag") then
                head.ESPNameTag:Destroy()
            end
        end
    end
end
