local Toggle = AimbotTab:CreateToggle({
   Name = "Aimbot",
   CurrentValue = false,
   Flag = "AimbotTogglePC", 
   Callback = function(Value)
       -- The variable (Value) is a boolean on whether the toggle is true or false
       _G.AimbotEnabled = Value

       local Players = game:GetService("Players")
       local LocalPlayer = Players.LocalPlayer
       local RunService = game:GetService("RunService")
       local Camera = workspace.CurrentCamera

       -- 1. PC COMPATIBLE FOV CIRCLE (No Drawing.new)
       if Value then
           if not _G.PC_FOV_Gui then
               local ScreenGui = Instance.new("ScreenGui")
               ScreenGui.Name = "TopsyFOV"
               ScreenGui.Parent = game:GetService("CoreGui")
               ScreenGui.IgnoreGuiInset = true
               
               local FOVFrame = Instance.new("Frame")
               FOVFrame.Name = "FOVFrame"
               FOVFrame.Parent = ScreenGui
               FOVFrame.AnchorPoint = Vector2.new(0.5, 0.5)
               FOVFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
               FOVFrame.BackgroundTransparency = 1 -- Hollow Middle
               FOVFrame.BorderSizePixel = 0
               
               local UICorner = Instance.new("UICorner")
               UICorner.CornerRadius = UDim.new(1, 0) -- Makes it a circle
               UICorner.Parent = FOVFrame
               
               local UIStroke = Instance.new("UIStroke")
               UIStroke.Thickness = 1.5
               UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
               UIStroke.Parent = FOVFrame
               
               _G.PC_FOV_Gui = ScreenGui
               _G.PC_FOV_Frame = FOVFrame
               _G.PC_FOV_Stroke = UIStroke
           end
           _G.PC_FOV_Frame.Visible = true
       else
           if _G.PC_FOV_Frame then
               _G.PC_FOV_Frame.Visible = false
           end
       end

       -- 2. TARGETING LOGIC
       local function getClosestPlayer()
           local closestPlayer = nil
           local shortestDistance = math.huge

           for _, player in ipairs(Players:GetPlayers()) do
               if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
                   local head = player.Character.Head
                   local screenPoint, onScreen = Camera:WorldToViewportPoint(head.Position)

                   if onScreen then
                       local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                       local distance = (Vector2.new(screenPoint.X, screenPoint.Y) - mousePos).Magnitude

                       -- Checks against the Slider value
                       if distance < (_G.AimbotFOV or 100) then
                           if distance < shortestDistance then
                               closestPlayer = player
                               shortestDistance = distance
                           end
                       end
                   end
               end
           end
           return closestPlayer
       end

       -- 3. THE LOOP
       RunService:BindToRenderStep("AimbotLoop", Enum.RenderPriority.Camera.Value, function()
           if _G.AimbotEnabled then
               -- Update FOV Visuals
               if _G.PC_FOV_Frame then
                   local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                   _G.PC_FOV_Frame.Position = UDim2.new(0, center.X, 0, center.Y)
                   
                   local size = (_G.AimbotFOV or 100) * 2
                   _G.PC_FOV_Frame.Size = UDim2.new(0, size, 0, size)
                   _G.PC_FOV_Stroke.Color = _G.FOV_Circle_Color or Color3.fromRGB(255, 255, 255)
               end

               -- Aim at target
               local target = getClosestPlayer()
               if target and target.Character and target.Character:FindFirstChild("Head") then
                   Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.Head.Position)
               end
           else
               if _G.PC_FOV_Frame then _G.PC_FOV_Frame.Visible = false end
               RunService:UnbindFromRenderStep("AimbotLoop")
           end
       end)

       if not Value then
           RunService:UnbindFromRenderStep("AimbotLoop")
       end
   end,
})
