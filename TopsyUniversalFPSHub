local AimbotTab = Window:CreateTab("Aimbot", nil) -- Title, Image
local AimbotSection = Tab:CreateSection("Aimbot")
local Button = Tab:CreateButton({
   Name = "Button Example",
   Callback = function()
  local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function applyESP(character)
	if not character or character == LocalPlayer.Character then return end
	
	local head = character:WaitForChild("Head", 10)
	if not head then return end

	-- 1. THE HIGHLIGHT (The "Glow")
	if not character:FindFirstChild("ESPHighlight") then
		local highlight = Instance.new("Highlight")
		highlight.Name = "ESPHighlight"
		highlight.Parent = character
		highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red
		highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White Outline
		highlight.FillTransparency = 0.5
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	end

	-- 2. THE NAME TAG (The "Username")
	if not head:FindFirstChild("ESPNameTag") then
		local player = Players:GetPlayerFromCharacter(character)
		
		local billboard = Instance.new("BillboardGui")
		billboard.Name = "ESPNameTag"
		billboard.Parent = head
		billboard.Size = UDim2.new(0, 200, 0, 50)
		billboard.StudsOffset = Vector3.new(0, 3, 0) -- Position above head
		billboard.AlwaysOnTop = true -- Vital for wallhacks
		
		local label = Instance.new("TextLabel")
		label.Parent = billboard
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.Text = player.DisplayName or player.Name
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextStrokeTransparency = 0 -- Makes text easier to read
		label.TextScaled = true
		label.Font = Enum.Font.GothamBold
	end
end

-- Setup for existing and new players
local function setupPlayer(player)
	player.CharacterAdded:Connect(applyESP)
	if player.Character then applyESP(player.Character) end
end

Players.PlayerAdded:Connect(setupPlayer)
for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end
