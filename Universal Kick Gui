local KickTab = Window:CreateTab("Kick", nil) -- Title, Image
local Section = KickTab:CreateSection("Kick")
local Dropdown = KickTab:CreateDropdown({
   Name = "Players List",
   Options = game:GetService("Players"):GetPlayers(), -- Initial load
   CurrentOption = {""},
   MultipleOptions = false,
   Flag = "Dropdown1",
   Callback = function(Options)
      -- The function that takes place when the selected option is changed
      -- The variable (Options) is a table of strings for the current selected options
      local Players = game:GetService("Players")
      
      local function getPlayerList()
          local names = {}
          for _, player in ipairs(Players:GetPlayers()) do
              table.insert(names, player.Name)
          end
          return names
      end

      -- Internal update logic to ensure names appear/disappear
      Players.PlayerAdded:Connect(function()
          Dropdown:Refresh(getPlayerList(), true)
      end)

      Players.PlayerRemoving:Connect(function()
          Dropdown:Refresh(getPlayerList(), true)
      end)

      local selectedUsername = Options[1]
      print("Currently interacting with: " .. tostring(selectedUsername))
   end,
})
local Button = KickTab:CreateButton({
   Name = "Kick Selected Player",
   Callback = function()
   -- The function that takes place when the button is pressed
   
   -- 1. Get the current selection from the Dropdown flag
   local selectedName = Dropdown.CurrentOption[1] 
   
   -- 2. Find that player in the game
   local targetPlayer = game:GetService("Players"):FindFirstChild(selectedName)
   
   -- 3. Kick them if they exist
   if targetPlayer then
       targetPlayer:Kick()
       print("Successfully kicked: " .. selectedName)
   else
       print("Player no longer in server.")
   end

   end,
})


